APP_ENV=production
LEAVE_SECRET=replace-with-a-long-random-secret

# Database
MYSQL_HOST=your-rds-endpoint.amazonaws.com
MYSQL_PORT=3306
MYSQL_DATABASE=permitrack
MYSQL_USER=permitrack_app
MYSQL_PASSWORD=replace-me

# Storage
STORAGE_BACKEND=s3
STORAGE_BUCKET=your-private-upload-bucket
STORAGE_PREFIX=permitrack
STORAGE_PRESIGNED_URL_EXPIRY=300

# AWS S3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-private-upload-bucket
AWS_S3_PREFIX=permitrack
AWS_PRESIGNED_URL_EXPIRY=300

# OCI Object Storage via S3-compatible API
# STORAGE_BACKEND=oci
# OCI_OBJECT_STORAGE_REGION=us-ashburn-1
# OCI_OBJECT_STORAGE_BUCKET=your-private-upload-bucket
# OCI_OBJECT_STORAGE_PREFIX=permitrack
# OCI_OBJECT_STORAGE_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
# OCI_S3_ACCESS_KEY=replace-me
# OCI_S3_SECRET_KEY=replace-me
# OCI_STORAGE_ADDRESSING_STYLE=path
# OCI_PRESIGNED_URL_EXPIRY=300

# Mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=replace-me
MAIL_DEFAULT_SENDER=mailer@example.com
MAIL_DELIVERY_MODE=sync

# Security
TRUST_PROXY=true
SESSION_COOKIE_SECURE=true
CSRF_ENABLED=true
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# Uploads
MAX_CONTENT_LENGTH=8388608
